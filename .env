# MongoDB connection string for the Express/Mongoose API
# Local non-Docker MongoDB:
MONGODB_URI=mongodb://myuser:mypassword@localhost:27017/brickstove?authSource=admin

# Docker Compose uses this internally:
# MONGODB_URI=mongodb://mongo:27017/brick-stove-builder

# API/server port
PORT=4174

# Optional CORS origin, e.g. http://localhost:5173
# CORS_ORIGIN=http://localhost:5173
