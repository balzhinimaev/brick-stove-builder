# MongoDB connection string for the Express/Mongoose API
# Local non-Docker MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/brick-stove-builder

# Docker Compose uses this internally:
# MONGODB_URI=mongodb://mongo:27017/brick-stove-builder

# API/server port
PORT=4174

# Secret used to sign stateless auth tokens (HMAC). REQUIRED in production:
# without it the server boots with a random per-restart secret, so every
# previously issued token stops working after a restart. Use a long random value.
AUTH_SECRET=change-me-to-a-long-random-string

# Optional CORS origin, e.g. http://localhost:5173
# CORS_ORIGIN=http://localhost:5173

# Optional frontend (see README): full API base URL, bypasses `/api` dev proxy when set
# VITE_API_BASE=http://127.0.0.1:4174/api

# Vite dev proxy target for `/api` (default http://127.0.0.1:4174)
# VITE_DEV_API_ORIGIN=http://127.0.0.1:4174
