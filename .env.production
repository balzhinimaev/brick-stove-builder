# Production web/APK build configuration.
#
# On a phone the app cannot use the relative "/api" path, so point this at the
# deployed backend before building a release APK, e.g.:
#   VITE_API_BASE=https://your-domain.tld/brick-stove-builder/api
#
# Left unset for now (build with `npm run android:apk` still produces an installable
# APK; configure the URL and rebuild before real use).
VITE_API_BASE=https://arcanabot.ru/brick-stove-builder/api
